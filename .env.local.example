# Configurações do Next.js
NEXT_PUBLIC_API_URL=http://localhost:3000

# Chaves do Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role-secreta

# Configurações do NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=uma-chave-secreta-para-o-nextauth

# Credenciais do Discord OAuth
DISCORD_CLIENT_ID=seu-client-id-do-discord
DISCORD_CLIENT_SECRET=seu-client-secret-do-discord

# Chaves do MercadoPago
MERCADOPAGO_ACCESS_TOKEN=seu-token-do-mercadopago

# Outras configurações
NODE_ENV=development
